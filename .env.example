# Public Supabase URL + publishable key are hardcoded in lib/supabase.ts
# and lib/supabase-admin.ts. Admin login credentials are hardcoded in
# lib/admin-auth.ts. No env vars needed for any of that.

# Server-only, required. Bypasses RLS — get from Supabase -> Project
# Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only, required once you have real Paystack keys.
PAYSTACK_SECRET_KEY=
