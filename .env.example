# Public Supabase URL + publishable key are hardcoded in lib/supabase.ts
# and lib/supabase-admin.ts — no env vars needed for those.

# Server-only, required. Bypasses RLS — get from Supabase -> Project
# Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only, required once you have real Paystack keys.
PAYSTACK_SECRET_KEY=

# Admin login (protects /admin). Set these in Vercel -> Settings ->
# Environment Variables — never commit real values here.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Random secret used to sign the admin session cookie. Any long random
# string works — generate a new one if you ever need to invalidate all
# active admin sessions at once.
ADMIN_SESSION_SECRET=
